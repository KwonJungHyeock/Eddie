# ============================================================
# EDDIE 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 복사하여 .env 라는 이름으로 저장
#         > copy .env.example .env
#   2. 각 항목에 실제 값 입력
#   3. .env 는 .gitignore 에 포함되어 있어 GitHub 에 올라가지 않음
# ============================================================

# --- Claude API (MOD-LLM-001) -----------------------------
# https://console.anthropic.com 에서 발급
# MOCK 모드일 때는 비워둬도 OK
ANTHROPIC_API_KEY=

# MOCK 모드 (Phase 1 초반 테스트용)
#   true  = 가짜 응답으로 코드 흐름 검증 (API 비용 0원)
#   false = 실제 Claude API 호출
EDDIE_MOCK_MODE=true

# 사용 모델 (Phase 1 본격 진입 시 결정)
EDDIE_DEFAULT_MODEL=claude-sonnet-4-5
EDDIE_FAST_MODEL=claude-haiku-4-5

# --- Brave Search API (MOD-TOL-001, Phase 1) --------------
# https://brave.com/search/api/ 무료 티어 월 2,000 query
BRAVE_API_KEY=

# --- Gmail API (MOD-TOL-004, Phase 5) ---------------------
# Google Cloud Console 에서 OAuth 클라이언트 생성
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080

# --- 사용자 정보 ------------------------------------------
# EDDIE 가 사용자를 호칭할 때 쓰는 이름 (PRS-001 기준 기본값: 소장님)
EDDIE_USER_TITLE=소장님

# --- 로깅 -------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/eddie.log
