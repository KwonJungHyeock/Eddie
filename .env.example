# EDDIE Environment Variables Template
#
# Usage:
#   1. Copy this file to .env :   copy .env.example .env
#   2. Fill real values for each item
#   3. .env is in .gitignore, never pushed to GitHub
#
# Document references: ARC-001 v0.3, PRS-001 v0.2, PLN-001 v0.2
# =============================================================

# --- Claude API (MOD-LLM-001) -------------------------------
# Source: https://console.anthropic.com
# Leave empty if EDDIE_MOCK_MODE=true
ANTHROPIC_API_KEY=

# MOCK mode toggle
#   true  = fake responses, no API calls (Step 1-2 / dev)
#   false = real Claude API (Step 1-3 / payment required)
EDDIE_MOCK_MODE=true

# Model selection (effective when MOCK_MODE=false)
EDDIE_DEFAULT_MODEL=claude-sonnet-4-5
EDDIE_FAST_MODEL=claude-haiku-4-5

# --- Tavily Search API (MOD-TOL-001) ------------------------
# Source: https://tavily.com
# Free tier: 1,000 credits/month, no card required (verified 2026-05)
# Key format: tvly-...
TAVILY_API_KEY=

# --- Gmail API (MOD-TOL-004, Phase 5) -----------------------
# Source: Google Cloud Console - OAuth 2.0 Client
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080

# --- User profile -------------------------------------------
# Title EDDIE addresses the user with (PRS-001 v0.2: 정혁님)
EDDIE_USER_TITLE=정혁님

# --- Logging ------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/eddie.log
